# ECHO Orchestrator - Environment Configuration

# Server
HOST=0.0.0.0
PORT=8020
DEBUG=false
ENVIRONMENT=development

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_LOCAL_MODEL=qwen2.5-coder:14b
OLLAMA_TIMEOUT_SECONDS=120

# Routing / approval
# Only for local development/tests - never set to true in production.
BYPASS_HUMAN_GATE=false

# Logging
LOG_FILE_PATH=logs/echo_metrics.jsonl
LOG_LEVEL=INFO

# CORS
# Comma-separated JSON list of allowed origins.
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
