# ─────────────────────────────────────────────────────────────────────────────
# ECHO Orchestrator — Environment Configuration
# Kopiere diese Datei nach .env und trage deine Werte ein.
# Committe NIEMALS die ausgefüllte .env ins Repository.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8020
DEBUG=false
ENVIRONMENT=development

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=dein_api_key_hier
DEFAULT_CLOUD_MODEL=claude-opus-4-6
ANTHROPIC_MAX_TOKENS=4096

# ── Ollama (lokal) ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_LOCAL_MODEL=echo-meta-14b
OLLAMA_TIMEOUT_SECONDS=120

# ── Routing ───────────────────────────────────────────────────────────────────
# Komplexitätsschwelle [0.0–1.0]: ab diesem Wert → Anthropic, darunter → Ollama
COMPLEXITY_THRESHOLD=0.6
# Nur für lokale Entwicklung/Tests — in production NIEMALS auf true setzen
BYPASS_HUMAN_GATE=false

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_FILE_PATH=logs/echo_metrics.jsonl
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────────────────
# Kommagetrennte Liste erlaubter Origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
