# ── ECHO Orchestrator — Beispiel-Konfiguration ───────────────────────────────
# Kopiere diese Datei nach .env und trage deine Werte ein.
# .env wird NICHT ins Repository committet (.gitignore).

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8020
DEBUG=false
ENVIRONMENT=development

# ── Anthropic (optional, nur für Hybrid-Routing) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_CLOUD_MODEL=claude-opus-4-6
ANTHROPIC_MAX_TOKENS=4096

# ── Ollama (lokal) ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_LOCAL_MODEL=qwen2.5-coder:14b
OLLAMA_TIMEOUT_SECONDS=120

# ── Routing ───────────────────────────────────────────────────────────────────
COMPLEXITY_THRESHOLD=0.6
BYPASS_HUMAN_GATE=false

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_FILE_PATH=logs/echo_metrics.jsonl
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
